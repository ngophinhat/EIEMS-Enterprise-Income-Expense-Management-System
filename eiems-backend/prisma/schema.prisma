// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS (Gia tri co dinh)
//////////////////////////////////////////////////////

enum Role {
  OWNER
  ADMIN
  ACCOUNTANT
  STAFF
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionAction {
  CREATE
  UPDATE
  ARCHIVE
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum DebtStatus {
  UNPAID
  PARTIAL
  PAID
}

enum TaxType {
  VAT
  CORPORATE
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model User {
  id       String  @id @default(uuid())
  fullName String
  email    String  @unique
  password String
  role     Role
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  debtPayments DebtPayment[]
  transactionLogs TransactionLog[]

  createdTransactions Transaction[] @relation("CreatedTransactions")
  updatedTransactions Transaction[] @relation("UpdatedTransactions")
  deletedTransactions Transaction[] @relation("DeletedTransactions")
}

//////////////////////////////////////////////////////
// CATEGORIES
//////////////////////////////////////////////////////

model Category {
  id       String       @id @default(uuid())
  name     String       @unique
  type     CategoryType
  isSystem Boolean      @default(false)
  isActive Boolean      @default(true)

  createdAt DateTime @default(now())

  transactions Transaction[]
}

//////////////////////////////////////////////////////
// TRANSACTIONS (THU / CHI)
//////////////////////////////////////////////////////

model Transaction {
  id              String          @id @default(uuid())
  type            TransactionType
  amount          Decimal         @db.Decimal(15, 2)
  note            String?
  isArchived      Boolean         @default(false)
  transactionDate DateTime
  logs TransactionLog[]

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  createdById String
  createdBy   User   @relation("CreatedTransactions", fields: [createdById], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  updatedById String?
  updatedBy   User?   @relation("UpdatedTransactions", fields: [updatedById], references: [id])

  deletedById String?
  deletedBy   User?   @relation("DeletedTransactions", fields: [deletedById], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([type])
  @@index([transactionDate])
  @@index([categoryId])
  @@index([isArchived])
}


//////////////////////////////////////////////////////
// TRANSACTIONLOG
//////////////////////////////////////////////////////


model TransactionLog {
  id            String            @id @default(uuid())
  action        TransactionAction
  changedFields Json?             // { amount: { from: 500000, to: 1000000 } }
  note          String?           // ghi chú lý do update

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  performedById String
  performedBy   User   @relation(fields: [performedById], references: [id])

  createdAt DateTime @default(now())

  @@index([transactionId])
  @@index([performedById])
}

//////////////////////////////////////////////////////
// CUSTOMERS
//////////////////////////////////////////////////////

model Customer {
  id      String  @id @default(uuid())
  name    String
  phone   String  @unique
  address String?

  debts Debt[]
  transactions Transaction[]
  
  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// DEBTS (CÔNG NỢ)
//////////////////////////////////////////////////////

model Debt {
  id              String  @id @default(uuid())
  totalAmount     Decimal @db.Decimal(15, 2)
  remainingAmount Decimal @db.Decimal(15, 2)

  status DebtStatus @default(UNPAID)

  dueDate DateTime?

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  payments DebtPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([customerId])
}

//////////////////////////////////////////////////////
// DEBT PAYMENTS
//////////////////////////////////////////////////////

model DebtPayment {
  id          String   @id @default(uuid())
  amount      Decimal  @db.Decimal(15, 2)
  paymentDate DateTime
  note        String?

  debtId String
  debt   Debt   @relation(fields: [debtId], references: [id])

  receivedById String
  receivedBy   User   @relation(fields: [receivedById], references: [id])

  createdAt DateTime @default(now())

  @@index([debtId])
}

//////////////////////////////////////////////////////
// Tax
//////////////////////////////////////////////////////
model Tax {
  id          String  @id @default(uuid())
  name        String
  type        TaxType
  rate        Decimal @db.Decimal(5, 4)
  description String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}